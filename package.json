{
  "name": "todo-tree-ng",
  "displayName": "ToDos",
  "description": "A lightweight TODO tree view for VS Code without ripgrep dependency",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:todoTreeView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "todoTreeContainer",
          "title": "TODOs",
          "icon": "media/todo-icon.svg"
        }
      ]
    },
    "views": {
      "todoTreeContainer": [
        {
          "id": "todoTreeView",
          "name": "TODOs",
          "when": "true"
        }
      ]
    },
    "commands": [
      {
        "command": "todo-tree-ng.refresh",
        "title": "Refresh TODOs",
        "icon": "$(refresh)"
      },
      {
        "command": "todo-tree-ng.openFile",
        "title": "Open File"
      },
      {
        "command": "todo-tree-ng.toggleFilter",
        "title": "Filter TODOs"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "todo-tree-ng.refresh",
          "when": "view == todoTreeView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "TODO Tree NG",
      "properties": {
        "todoTreeNG.include": {
          "type": "array",
          "default": [
            "**/*.ts",
            "**/*.tsx",
            "**/*.js",
            "**/*.jsx",
            "**/*.py",
            "**/*.java",
            "**/*.cs",
            "**/*.go",
            "**/*.rs",
            "**/*.rb",
            "**/*.php",
            "**/*.cpp",
            "**/*.c",
            "**/*.h",
            "**/*.css",
            "**/*.html",
            "**/*.md",
            "**/*.sh",
            "**/*.yml",
            "**/*.yaml",
            "**/*.json"
          ],
          "description": "File patterns to include in TODO scanning"
        },
        "todoTreeNG.exclude": {
          "type": "array",
          "default": [
            "**/node_modules",
            "**/.git",
            "**/dist",
            "**/build",
            "**/.vscode",
            "**/venv",
            "**/__pycache__"
          ],
          "description": "File patterns to exclude from TODO scanning"
        },
        "todoTreeNG.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh TODOs on file changes"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "glob": "^13.0.6",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
